# ============================================================
# .env.example — Template สำหรับ Environment Variables
# ============================================================
# ไฟล์นี้ commit ขึ้น Git ได้ เพราะไม่มีค่าจริง
# ให้ developer copy ไฟล์นี้เป็น .env แล้วใส่ค่าจริงเอง
#
# คำสั่ง: cp .env.example .env
#
# NEVER commit .env จริงลง Git เด็ดขาด
# เพราะ GitHub เป็นที่แรกที่ attacker จะไปหา credentials

# ---- Server Configuration ----
NODE_ENV=development
PORT=3000

# ---- Database ----
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# ---- JWT ----
JWT_SECRET=replace_with_a_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=another_long_random_string_for_refresh_tokens
REFRESH_TOKEN_EXPIRES_IN=7d

# ---- External APIs ----
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
SENDGRID_API_KEY=SG.your_sendgrid_key_here
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# ---- Redis (สำหรับ JWT Deny List / Session) ----
REDIS_URL=redis://localhost:6379

# ---- Storage ----
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_bucket_name
